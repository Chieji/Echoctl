# =============================================================================
# EchoCTL — Environment Variables (read-only fallback for credentials)
# =============================================================================
# These are used as fallback when no stored credential exists.
# Stored credentials (via `echoctl login`) always take precedence.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_API_KEY=
FIREWORKS_API_KEY=
TOGETHER_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
