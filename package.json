{
  "name": "echo-ai-cli",
  "version": "1.0.0",
  "description": "Echo - The Resilient Agentic Terminal with multi-provider AI, auto-failover, and plugin sync",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "echoctl": "./dist/index.js",
    "echo": "./dist/index.js"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "./build.sh",
    "start": "node dist/index.js",
    "dev": "npm run build && node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "echo \"Lint coming soon\" && exit 0",
    "prepublishOnly": "npm run build",
    "postinstall": "echo \"✓ Echo CLI installed! Run 'echo --help' to get started.\""
  },
  "keywords": [
    "cli",
    "ai",
    "chat",
    "openai",
    "gemini",
    "anthropic",
    "assistant"
  ],
  "author": "chieji <chieji4thson+github@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chieji/echoctl.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "box-node-sdk": "^10.4.0",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "cli-highlight": "^2.1.11",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "conf": "^13.1.0",
    "enquirer": "^2.4.1",
    "figlet": "^1.10.0",
    "gradient-string": "^2.0.2",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "lowdb": "^7.0.1",
    "ora": "^8.1.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/gradient-string": "^1.1.5",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ]
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
