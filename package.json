{
  "name": "echo-ai-cli",
  "version": "1.0.0",
  "description": "Echo - The Resilient Agentic Terminal with multi-provider AI, auto-failover, and plugin sync",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "echo": "./dist/index.js"
  },
  "scripts": {
    "build": "./build.sh",
    "start": "node dist/index.js",
    "dev": "npm run build && node dist/index.js",
    "test": "echo \"Tests coming soon\" && exit 0",
    "lint": "echo \"Lint coming soon\" && exit 0",
    "prepublishOnly": "npm run build",
    "postinstall": "echo \"✓ Echo CLI installed! Run 'echo --help' to get started.\""
  },
  "keywords": [
    "cli",
    "ai",
    "chat",
    "openai",
    "gemini",
    "anthropic",
    "assistant"
  ],
  "author": "chieji <chieji4thson+github@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chieji/echoctl.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "conf": "^13.1.0",
    "enquirer": "^2.4.1",
    "figlet": "^1.10.0",
    "gradient-string": "^2.0.2",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "lowdb": "^7.0.1",
    "ora": "^8.1.0",
    "react": "^19.2.4",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/gradient-string": "^1.1.5",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
