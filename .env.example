# =============================================================================
# ECHOMEN Website — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in the values for your environment.

# --- Sentry (error tracking) ---
# Create a project at https://sentry.io, then add the DSN here.
# Server-side DSN (used by server/index.ts)
SENTRY_DSN=
# Client-side DSN (used by client/src/main.tsx via Vite)
VITE_SENTRY_DSN=

# --- OAuth (Manus login — currently unused, reserved for future features) ---
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Vite Build ---
# Override the base path for production builds (defaults to /echomen-website/)
# Set to '/' if deploying to a custom domain root.
VITE_BASE_PATH=

# --- Storage Proxy (dev only — requires Manus Forge credentials) ---
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=
